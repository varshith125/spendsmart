# MongoDB connection string
MONGODB_URI=

# Secret for JWT signing
JWT_SECRET=

# The URL of your frontend (on Vercel)
# Example: https://spendsmart.vercel.app
CLIENT_URL=

# Gemini API Key for AI Insights
# Get one at https://aistudio.google.com/
GEMINI_API_KEY=

# Port number (optional, defaulted to 5000)
PORT=5000
